{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.27/MicrosoftTeams.schema.json",
    "manifestVersion": "1.27",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Pavel Vecer",
        "websiteUrl": "https://github.com/pavecer/servicenow-mcp-apps-copilot",
        "privacyUrl": "https://github.com/pavecer/servicenow-mcp-apps-copilot/blob/main/README.md",
        "termsOfUseUrl": "https://github.com/pavecer/servicenow-mcp-apps-copilot/blob/main/LICENSE"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "ServiceNow Catalog${{APP_NAME_SUFFIX}}",
        "full": "ServiceNow Catalog (MCP Apps)"
    },
    "description": {
        "short": "Order ServiceNow catalog items from Microsoft 365 Copilot.",
        "full": "Browse the ServiceNow service catalog, place orders, and manage existing requests from inside Microsoft 365 Copilot using interactive MCP App widgets. Backed by the open-source servicenow-mcp-apps-copilot project."
    },
    "accentColor": "#FFFFFF",
    "supportsChannelFeatures": "tier1",
    "composeExtensions": [],
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": [
        "<your-funcapp>.azurewebsites.net"
    ]
}
