{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.27/MicrosoftTeams.schema.json",
    "manifestVersion": "1.27",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "mcp-server-servicenow",
        "websiteUrl": "https://github.com/pavecer/mcp-server-servicenow",
        "privacyUrl": "https://github.com/pavecer/mcp-server-servicenow/blob/main/README.md",
        "termsOfUseUrl": "https://github.com/pavecer/mcp-server-servicenow/blob/main/LICENSE"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "ServiceNow Catalog${{APP_NAME_SUFFIX}}",
        "full": "ServiceNow Catalog (MCP Apps)"
    },
    "description": {
        "short": "Order ServiceNow catalog items from Microsoft 365 Copilot.",
        "full": "Browse the ServiceNow service catalog, place orders, and manage existing requests from inside Microsoft 365 Copilot using interactive MCP App widgets. Backed by the open-source mcp-server-servicenow project."
    },
    "accentColor": "#FFFFFF",
    "supportsChannelFeatures": "tier1",
    "composeExtensions": [],
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": [
        "func-yj453fjwuhph4.azurewebsites.net",
        "8c1a8071abbb5bd95e87ab241a633d52.widget-renderer.usercontent.microsoft.com",
        "53337d3f36fd3b14a29eaa6f6a856566.widget-renderer.usercontent.microsoft"
    ]
}
