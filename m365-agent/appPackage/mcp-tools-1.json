            }
        },
        {
            "name": "update_order_item",
            "description": "Update a single requested item (line item) on an existing order — change its quantity or add a comment/description — without touching the rest of the order. Renders the refreshed order-detail widget.",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "orderItemSysId": {
                        "type": "string",
                        "description": "The sys_id of the requested item (sc_req_item) to update"
                    },
                    "orderSysId": {
                        "type": "string",
                        "description": "Optional sys_id of the parent order (sc_request); resolved from the item when omitted"
                    },
                    "updates": {
                        "type": "object",
                        "description": "Allowed fields: quantity, comments, short_description, description",
                        "additionalProperties": false,
                        "properties": {
                            "quantity": {
                                "type": [
                                    "string",
                                    "number"
                                ]
                            },
                            "comments": {
                                "type": "string"
                            },
                            "short_description": {
                                "type": "string"
                            },
                            "description": {
                                "type": "string"
                            }
                        }
                    }
                },
                "required": [
                    "orderItemSysId",
                    "updates"
                ]
            },
            "_meta": {
                "ui": {
                    "resourceUri": "ui://servicenow-mcp/order-detail.html",
                    "visibility": [
                        "model",
                        "app"
                    ]
                },
                "ui/resourceUri": "ui://servicenow-mcp/order-detail.html",
                "openai/outputTemplate": "ui://servicenow-mcp/order-detail.html",
                "openai/widgetAccessible": true,
                "openai/visibility": "public"
            },
            "annotations": {
                "readOnlyHint": true
            }
        },
        {
            "name": "remove_order_item",
            "description": "Remove a single requested item (line item) from an existing order without cancelling the whole request. Renders the refreshed order-detail widget.",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "orderItemSysId": {
                        "type": "string",
                        "description": "The sys_id of the requested item (sc_req_item) to remove"
                    },
                    "orderSysId": {
                        "type": "string",
                        "description": "Optional sys_id of the parent order (sc_request); resolved from the item when omitted"
                    }
                },
                "required": [
                    "orderItemSysId"
                ]
            },
