{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.21/MicrosoftTeams.schema.json",
  "manifestVersion": "1.21",
  "version": "1.0.0",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "mcp-server-servicenow contributors",
    "websiteUrl": "https://github.com/pavecer/mcp-server-servicenow",
    "privacyUrl": "https://github.com/pavecer/mcp-server-servicenow/blob/main/README.md",
    "termsOfUseUrl": "https://github.com/pavecer/mcp-server-servicenow/blob/main/LICENSE"
  },
  "name": {
    "short": "ServiceNow Catalog",
    "full": "ServiceNow Catalog (MCP)"
  },
  "description": {
    "short": "Order ServiceNow catalog items from Microsoft 365 Copilot.",
    "full": "Declarative agent and MCP App widgets that let employees browse the ServiceNow service catalog, place orders, and manage existing requests from inside Microsoft 365 Copilot. Backed by the open-source mcp-server-servicenow project."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0078D4",
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "servicenow-catalog",
        "file": "declarativeAgent.json"
      }
    ]
  },
  "validDomains": [
    "${{MCP_SERVER_DOMAIN}}",
    "widget-renderer.usercontent.microsoft.com"
  ]
}
